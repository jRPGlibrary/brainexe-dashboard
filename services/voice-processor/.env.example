# Voice Processor Configuration

# Server
VOICE_PORT=3002
NODE_ENV=development

# Home Assistant
HOME_ASSISTANT_URL=http://localhost:8123
HOME_ASSISTANT_TOKEN=your_long_lived_token

# Speech-to-Text Provider
SPEECH_PROVIDER=whisper  # or 'google'
OPENAI_API_KEY=sk-...  # For Whisper
GOOGLE_CLOUD_KEY=...  # For Google Speech

# LLM (for natural language understanding)
ANTHROPIC_API_KEY=sk-ant-...  # Claude (Recommended)

# Optional: Brainexe & Discord URLs (for command routing)
BRAINEXE_URL=http://localhost:3001
DISCORD_URL=http://localhost:8000
