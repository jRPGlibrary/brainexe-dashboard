# Clé Anthropic (obligatoire — utilisée pour la réflexion de NEX)
ANTHROPIC_API_KEY=sk-ant-...

# Clé OpenAI optionnelle — pour la transcription Whisper en mode vocal
# Laisse vide pour utiliser le CLI whisper local ou le mode texte
OPENAI_API_KEY=

# Modèle Claude à utiliser
CLAUDE_MODEL=claude-sonnet-4-6

# Mode par défaut : "text" ou "voice"
# Peut être surchargé avec --text ou --voice en argument
NEX_MODE=text

# Langue de la voix espeak-ng (ex: fr, fr+m3, en+m1)
# fr+m3 = voix masculine française, variante 3
VOICE_LANG=fr+m3

# Prénom de l'utilisateur (personnalise les salutations)
USER_NAME=
